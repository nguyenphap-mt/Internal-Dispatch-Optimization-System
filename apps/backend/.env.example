# Backend configuration
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=dispatch
DB_PASSWORD=dispatch
DB_NAME=dispatch
DB_SYNCHRONIZE=true
DB_LOGGING=false

# Auth
JWT_SECRET=dispatch-dev-secret
JWT_EXPIRES_IN=12h

# CORS (frontend origin); * for dev
CORS_ORIGIN=*

# Optional self-hosted OSRM routing service. Leave empty to use the
# built-in Haversine fallback (zero external dependency).
OSRM_URL=
